generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  email_verified_at DateTime?
  password          String
  remember_token    String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("users")
}


model MedicalTermTranslation {
  id              Int          @id @default(autoincrement())
  medical_term_id Int
  language_id     Int
  name            String       @db.VarChar(255)
  description     String       @db.Text
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  // Faqat bittadan qoldirildi:
  language        Language     @relation(fields: [language_id], references: [id])
  term            MedicalTerm  @relation(fields: [medical_term_id], references: [id])

  @@map("medical_term_translations")
}

model Language {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  name       String
  flag       String   // Rasm URL manzili uchun
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  translations MedicalTermTranslation[] 

  @@map("languages") // Bazadagi jadval nomi 'languages' ekanligini bildiradi
}

model MedicalTerm {
  id           Int                      @id @default(autoincrement())
  translations MedicalTermTranslation[]
  created_at   DateTime                 @default(now())
  updated_at   DateTime                 @updatedAt

  @@map("medical_terms")
}

model Abbreviations {
  id              Int         @id @default(autoincrement())
  title           String
  description     String      @db.Text
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  @@map("abbreviations")
}



